# ==============================================================
# Orchard e2e — pinned container image versions
# ==============================================================
# Single source of truth for every image tag used across the e2e
# matrix. Updating a value here updates every config at once.
#
# Loaded by e2e/docker/scripts/compose.sh via --env-file before
# the per-config env file, so per-config envs can override a tag
# for one matrix entry if ever needed.
#
# The `# renovate:` comments enable automated bump PRs from
# Renovate (ignored when Renovate is not configured).

# renovate: datasource=docker depName=polarlightning/lnd
LND_VERSION=0.20.0-beta

# renovate: datasource=docker depName=polarlightning/clightning
CLN_VERSION=25.12

# renovate: datasource=docker depName=polarlightning/bitcoind
BITCOIND_VERSION=30.0

# renovate: datasource=docker depName=polarlightning/tapd
TAPD_VERSION=0.7.0-alpha

# renovate: datasource=docker depName=polarlightning/litd
# lnd-cdk-sqlite uses litd (bundled lnd+tapd) on orchard+alice so the fixture
# can open asset-backed LN channels via `litcli ln fundchannel --asset_id`.
LITD_VERSION=0.16.0-alpha

# renovate: datasource=docker depName=postgres
POSTGRES_VERSION=18-alpine

# renovate: datasource=docker depName=cashubtc/mintd
CDK_MINTD_VERSION=v0.16.0

# renovate: datasource=crate depName=cdk-cli
CDK_CLI_VERSION=0.16.0

# renovate: datasource=docker depName=cashubtc/nutshell
NUTSHELL_VERSION=0.20.0
