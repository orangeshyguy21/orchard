# ==============================================================
# Orchard e2e — fake-cdk-postgres (cdk-mintd fake_wallet + postgres, no LN, no BTC)
# ==============================================================
# Consumed by docker compose (variable substitution + env_file for orchard).
# All values are regtest-only — DO NOT reuse in any real deployment.
#
# This stack has no Lightning node AND no Bitcoin node. cdk-mintd runs with
# fake_wallet serving both sat and usd units; Orchard boots without a
# LIGHTNING_TYPE and without a BITCOIN_TYPE. Its job is to exercise multi-
# unit mint flows (keysets, balances, mgmt RPC) and to prove that Orchard
# UI surfaces tolerate both optional services being absent.

# ----- Postgres -----
PG_USER=cashu
PG_PASS=cashu
PG_DB=cdk_fake

# ----- Orchard server config -----
SETUP_KEY=orchard-e2e-admin-key
ADMIN_PASSWORD=orchard-e2e-admin-key
LOG_LEVEL=debug
BASE_PATH=api

# ----- Orchard → Bitcoin -----
# Deliberately absent — this stack has no bitcoind. main.ts:59-60 only errors
# on invalid BITCOIN_TYPE values; omitting it is supported.

# ----- Orchard → Lightning -----
# Deliberately absent — this stack has no LN node. main.ts:62-64 only errors
# on invalid LIGHTNING_TYPE values; omitting it is supported.

# ----- Orchard → Mint (cdk-mintd, fake backend) -----
MINT_TYPE=cdk
MINT_API=http://cdk-mintd:3341
# MINT_DATABASE (postgres URL) set inline in compose
MINT_RPC_HOST=cdk-mintd
MINT_RPC_PORT=8087
MINT_RPC_MTLS=false

# Throttler bumped above defaults so the Playwright suite's serial dashboard
# navigations (6+ tests per spec across 5 stacks) do not trip the default
# 20 req / 60s limit. Production stays on the defaults via
# src/server/config/configuration.ts.
THROTTLE_LIMIT=1000
THROTTLE_TTL=60000
