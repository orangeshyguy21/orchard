# Orchard e2e global overrides
# Copy to `e2e/.env` (gitignored) and edit for your machine.
#
# Load order:
# 1) e2e/docker/versions.env
# 2) e2e/docker/configs/<stack>/env
# 3) e2e/.env                     (this file, when copied)

# ==============================================================
# Cadence activity runner defaults (host-side)
# ==============================================================
# ACTIVITY_INTERVAL_SECONDS=90
# ACTIVITY_JITTER_SECONDS=15
# ACTIVITY_DISRUPT_SECONDS=4
# ACTIVITY_DISRUPT_EVERY=1
# ACTIVITY_RECOVERY_TIMEOUT=60
# ACTIVITY_SEED=12345

# ==============================================================
# Mainchain / host integration defaults
# Used by bootstrap-mainchain.sh and compose overlay substitution.
# ==============================================================
# BITCOIN_CLI=/usr/local/bin/bitcoin-cli
# BITCOIN_CLI_ARGS='-rpcuser=you -rpcpassword=secret'
# HOST_BITCOIN_P2P_PORT=8333

# ==============================================================
# Mainchain bitcoind IBD throttle (e2e/docker/configs/cln-nutshell-postgres/compose.mainchain.yml)
# Defaults are bitcoind's own (fast). Uncomment to soften CPU/RAM on a battery-
# bound laptop. Trade-off: slower post-snapshot catch-up, but only happens once.
# ==============================================================
# MAINCHAIN_PAR=2          # script verification threads (default 0=auto/all-cores). Biggest CPU lever.
# MAINCHAIN_DBCACHE=200    # UTXO db cache MiB (default 450). Biggest RAM lever.
# MAINCHAIN_BLOCKSONLY=1   # disable tx relay/mempool churn (default 0). Cheap CPU win for an IBD-only node.
# MAINCHAIN_MAXMEMPOOL=50  # mempool ceiling MiB (default 300). Pairs with BLOCKSONLY=1.
